{
  "name": "Subliminal Player",
  "short_name": "Subliminal",
  "description": "Mindful offline music player with subliminal support.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#FFFFFF",
  "theme_color": "#007AFF",
  "icons": [
    {
      "src": "https://picsum.photos/seed/subliminal_icon_192/192/192",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "https://picsum.photos/seed/subliminal_icon_512/512/512",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "audio_files",
          "accept": ["audio/*", ".m4a", ".mp3", ".wav", ".aac", "audio/mp4", "audio/x-m4a"]
        }
      ]
    }
  }
}
